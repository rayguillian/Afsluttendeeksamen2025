{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "predeploy": ["npm --prefix \"$PROJECT_DIR\" run build"],
    "rewrites": [
      {
        "source": "/api/**",
        "function": { "functionId": "api", "region": "europe-west1" }
      },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/data/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      },
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "predeploy": [
      "cp \"$PROJECT_DIR/server.mjs\" \"$PROJECT_DIR/recipe_sources.mjs\" \"$RESOURCE_DIR/\""
    ]
  }
}
