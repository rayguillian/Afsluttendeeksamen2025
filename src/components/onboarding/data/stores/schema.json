{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "store": {
      "type": "object",
      "required": ["id", "chain", "name", "location", "hours", "inventory"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the store"
        },
        "chain": {
          "type": "string",
          "enum": [
            "Rema 1000",
            "Føtex",
            "Netto",
            "Lidl",
            "Bilka",
            "Aldi",
            "Meny"
          ]
        },
        "name": {
          "type": "string",
          "description": "Store name with location, e.g. 'Rema 1000 Nørrebro'"
        },
        "location": {
          "type": "object",
          "required": ["address", "coordinates", "district"],
          "properties": {
            "address": {
              "type": "string"
            },
            "coordinates": {
              "type": "object",
              "required": ["lat", "lng"],
              "properties": {
                "lat": {
                  "type": "number",
                  "minimum": 55.5,
                  "maximum": 55.8
                },
                "lng": {
                  "type": "number",
                  "minimum": 12.4,
                  "maximum": 12.7
                }
              }
            },
            "district": {
              "type": "string",
              "enum": [
                "Nørrebro",
                "Østerbro",
                "Vesterbro",
                "Frederiksberg",
                "Amager",
                "Indre By",
                "Valby",
                "Vanløse",
                "Brønshøj-Husum"
              ]
            }
          }
        },
        "hours": {
          "type": "object",
          "required": ["weekday", "saturday", "sunday"],
          "properties": {
            "weekday": {
              "type": "string",
              "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]-([01]?[0-9]|2[0-3]):[0-5][0-9]$"
            },
            "saturday": {
              "type": "string",
              "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]-([01]?[0-9]|2[0-3]):[0-5][0-9]$"
            },
            "sunday": {
              "type": "string",
              "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]-([01]?[0-9]|2[0-3]):[0-5][0-9]$"
            }
          }
        },
        "inventory": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/product"
          }
        }
      }
    },
    "product": {
      "type": "object",
      "required": ["id", "name", "category", "price", "unit", "inStock"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "Kød og Fjerkræ",
            "Grøntsager og Frugt",
            "Mejeri og Æg",
            "Kolonial",
            "Krydderier",
            "Korn og Pasta"
          ]
        },
        "price": {
          "type": "object",
          "required": ["regular", "discount", "discountPercentage"],
          "properties": {
            "regular": {
              "type": "number",
              "minimum": 0
            },
            "discount": {
              "type": "number",
              "minimum": 0
            },
            "discountPercentage": {
              "type": "number",
              "minimum": 29,
              "maximum": 34
            }
          }
        },
        "unit": {
          "type": "string",
          "enum": ["stk", "g", "kg", "ml", "l", "bundt"]
        },
        "inStock": {
          "type": "boolean"
        },
        "dietaryTags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "vegetar",
              "veganer",
              "glutenfri",
              "laktosefri",
              "økologisk",
              "halal"
            ]
          }
        },
        "allergens": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "gluten",
              "mælk",
              "skaldyr",
              "æg",
              "nødder",
              "soja"
            ]
          }
        }
      }
    }
  }
}
