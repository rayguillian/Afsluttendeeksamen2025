# KøbSmart local demo — server-side secrets only. Never exposed to the browser.

# DeepSeek API key. Without it, the app shows a clear "recipe generation
# unavailable" state instead of faking recipes.
DEEPSEEK_API_KEY=

# Optional overrides
# DEEPSEEK_MODEL=deepseek-chat
# API_PORT=5174
# Optional server-side Google Routes API key. Without it, routing uses
# transport-aware open providers and the UI can still open routes in Google Maps.
# GOOGLE_MAPS_API_KEY=
# GOOGLE_ROUTES_URL=https://routes.googleapis.com/directions/v2:computeRoutes
# OSRM_URL=https://router.project-osrm.org
# OSRM_DRIVING_URL=https://router.project-osrm.org
# OSRM_CYCLING_URL=https://routing.openstreetmap.de/routed-bike
# OSRM_WALKING_URL=https://routing.openstreetmap.de/routed-foot
# RECIPE_SOURCE_LOOKUP=true
# RECIPE_SOURCE_CACHE_HOURS=720
# RECIPE_SOURCE_TIMEOUT_MS=7000
